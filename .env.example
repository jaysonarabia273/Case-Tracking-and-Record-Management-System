# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Google OAuth2 Settings
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your-google-oauth-key.apps.googleusercontent.com
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your-google-oauth-secret

# Email Configuration (Brevo SMTP)
EMAIL_HOST_USER=your-brevo-user@smtp-brevo.com
EMAIL_HOST_PASSWORD=your-brevo-password
DEFAULT_FROM_EMAIL=Your App <your-email@example.com>
